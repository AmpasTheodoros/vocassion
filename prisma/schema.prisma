generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id                      String                     @id
  userId                  String                     @unique
  username                String                     @unique
  name                    String?
  slug                    String                     @unique
  imageUrl                String?
  email                   String                     @unique
  bio                     String?
  headline                String?
  location                String?
  website                 String?
  github                  String?
  linkedin                String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  achievements            Achievement[]
  challenges              Challenge[]
  comments                Comment[]
  communities             CommunityMember[]
  communityPosts          CommunityPost[]
  postLikes               CommunityPostLike[]
  dailyReflections        DailyReflection[]
  feedbacks               Feedback[]
  goals                   Goal[]
  ikigaiMap               IkigaiMap?
  journalEntries          JournalEntry[]
  mainGoals               MainGoal[]
  miniGames               MiniGame[]
  penalties               Penalty[]
  progressLevels          ProgressLevel[]
  resources               Resource[]
  rewards                 Reward[]
  stories                 Story[]                    @relation("AuthoredStories")
  streaks                 Streak[]
  teamChallenges          TeamChallenge[]            @relation("CreatedChallenges")
  challengeParticipations TeamChallengeParticipant[]
}

model IkigaiMap {
  id         String   @id @default(cuid())
  userId     String   @unique
  passion    String[]
  profession String[]
  mission    String[]
  vocation   String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       Profile  @relation(fields: [userId], references: [userId])
}

model Challenge {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String
  type        String
  status      String
  points      Int
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        Profile   @relation(fields: [userId], references: [userId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  category    String
  points      Int
  unlockedAt  DateTime @default(now())
  user        Profile  @relation(fields: [userId], references: [userId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mood      String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      Profile  @relation(fields: [userId], references: [userId])
}

model Community {
  id          String            @id @default(cuid())
  name        String
  description String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     CommunityMember[]
  posts       CommunityPost[]   @relation("CommunityPosts")
}

model CommunityMember {
  id          String    @id @default(cuid())
  userId      String
  communityId String
  role        String
  joinedAt    DateTime  @default(now())
  community   Community @relation(fields: [communityId], references: [id])
  user        Profile   @relation(fields: [userId], references: [userId])

  @@unique([userId, communityId])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String
  type         String
  currentCount Int      @default(0)
  longestCount Int      @default(0)
  lastCheckin  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         Profile  @relation(fields: [userId], references: [userId])

  @@unique([userId, type])
}

model Reward {
  id          String   @id @default(cuid())
  userId      String
  description String
  points      Int
  createdAt   DateTime @default(now())
  user        Profile  @relation(fields: [userId], references: [userId])
}

model DailyReflection {
  id         String   @id @default(cuid())
  userId     String
  content    String
  mood       String
  gratitude  String
  challenges String
  wins       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile  @relation(fields: [userId], references: [userId])

  @@index([userId])
}

model Goal {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String
  category    String
  status      String
  deadline    DateTime?
  progress    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        Profile   @relation(fields: [userId], references: [userId])
  tasks       Task[]
}

model Task {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  category    String
  url         String
  tags        String[]
  likes       Int      @default(0)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        Profile  @relation(fields: [userId], references: [userId])
}

model Story {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  tags      String[]
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    Profile  @relation("AuthoredStories", fields: [authorId], references: [userId])
}

model MiniGame {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  category    String
  content     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plays       Int      @default(0)
  userId      String
  user        Profile  @relation(fields: [userId], references: [userId])
}

model CommunityPost {
  id          String              @id @default(cuid())
  title       String
  content     String
  type        PostType            @default(reflection)
  userId      String
  communityId String
  likeCount   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  comments    Comment[]
  community   Community           @relation("CommunityPosts", fields: [communityId], references: [id])
  user        Profile             @relation(fields: [userId], references: [userId])
  userLikes   CommunityPostLike[]
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      Profile       @relation(fields: [userId], references: [userId])
}

model MainGoal {
  id           String     @id @default(cuid())
  userId       String
  title        String
  description  String
  category     String
  difficulty   String
  status       String
  progress     Int        @default(0)
  pointsCost   Int
  pointsReward Int
  deadline     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  feedback     Feedback[]
  user         Profile    @relation(fields: [userId], references: [userId])
  subGoals     SubGoal[]
}

model SubGoal {
  id           String      @id @default(cuid())
  mainGoalId   String
  title        String
  description  String
  order        Int
  status       String
  progress     Int         @default(0)
  pointsReward Int
  deadline     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  milestones   Milestone[]
  mainGoal     MainGoal    @relation(fields: [mainGoalId], references: [id], onDelete: Cascade)
}

model Milestone {
  id           String   @id @default(cuid())
  subGoalId    String
  title        String
  description  String?
  isCompleted  Boolean  @default(false)
  pointsReward Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  subGoal      SubGoal  @relation(fields: [subGoalId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String   @id @default(cuid())
  mainGoalId String
  userId     String
  content    String
  type       String
  createdAt  DateTime @default(now())
  mainGoal   MainGoal @relation(fields: [mainGoalId], references: [id])
  user       Profile  @relation(fields: [userId], references: [userId])
}

model ProgressLevel {
  id         String   @id @default(cuid())
  userId     String
  category   String
  level      Int      @default(1)
  currentXP  Int      @default(0)
  requiredXP Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       Profile  @relation(fields: [userId], references: [userId])
}

model Penalty {
  id         String   @id @default(cuid())
  userId     String
  reason     String
  pointsLost Int
  createdAt  DateTime @default(now())
  user       Profile  @relation(fields: [userId], references: [userId])
}

model TeamChallenge {
  id           String                     @id @default(cuid())
  creatorId    String
  title        String
  description  String
  category     String
  rewardPoints Int
  endDate      DateTime
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  creator      Profile                    @relation("CreatedChallenges", fields: [creatorId], references: [userId])
  participants TeamChallengeParticipant[]
}

model TeamChallengeParticipant {
  id          String        @id @default(cuid())
  challengeId String
  userId      String
  joinedAt    DateTime      @default(now())
  status      String
  progress    Int           @default(0)
  challenge   TeamChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        Profile       @relation(fields: [userId], references: [userId])

  @@unique([challengeId, userId])
}

model CommunityPostLike {
  id        String        @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      Profile       @relation(fields: [userId], references: [userId])

  @@unique([postId, userId])
}

enum PostType {
  achievement
  challenge
  reflection
  map
}
